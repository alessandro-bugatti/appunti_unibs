    </attributes>
    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="voto" type="Integer" array="False" size=""/>
            <input variable="voto"/>
            <if expression="voto &lt; 18">
                <then>
                    <output expression="&quot;RIPETERE ESAME&quot;" newline="True"/>
                </then>
                <else>
                    <if expression="voto &gt; 24">
                        <then>
                            <output expression="&quot;DA REGISTRARE&quot;" newline="True"/>
                        </then>
                        <else>
                            <output expression="&quot;ORALE OPZIONALE&quot;" newline="True"/>
                        </else>
                    </if>
                </else>
            </if>
        </body>
    </function>
</flowgorithm>
